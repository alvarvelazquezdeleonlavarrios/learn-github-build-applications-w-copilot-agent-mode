# Vite Environment Variables for OctoFit Tracker Frontend
# 
# VITE_CODESPACE_NAME: Required for Codespaces deployment
# Set this to your Codespace name to enable API calls to the backend
# Format: https://${VITE_CODESPACE_NAME}-8000.app.github.dev/api
#
# If VITE_CODESPACE_NAME is not set, the app falls back to localhost:8000

# Example for Codespaces:
# VITE_CODESPACE_NAME=my-codespace-name

# Local development (leave empty or commented out to use localhost):
# VITE_CODESPACE_NAME=
